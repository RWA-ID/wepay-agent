# ─── MoonPay ────────────────────────────────────────────────────────────────
# CLI auth is handled locally via `mp login` — no API key needed here.
# Run `mp login --email you@example.com` on the agent host before deploying.
MOONPAY_WEBHOOK_SECRET=whsec_...   # For verifying payment webhook signatures
# Treasury wallet — receives the $99/year USDC payments
WEPAY_TREASURY_ADDRESS=0x...

# ─── Pinata ─────────────────────────────────────────────────────────────────
PINATA_JWT=...
PINATA_GATEWAY=https://your-gateway.mypinata.cloud

# ─── OWS (Open Wallet Standard) ─────────────────────────────────────────────
VAULT_ENCRYPTION_SECRET=...       # 32-char random secret for AES vault encryption
OWS_VAULT_DIR=/home/app/.ows      # Directory for encrypted vault blobs

# ─── Database (Postgres) ────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@localhost:5432/wepay

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=...                    # 64-char random secret for JWT signing
JWT_EXPIRES_IN=7d

# ─── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=...

# ─── WhatsApp Business API ───────────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=...
WHATSAPP_PHONE_NUMBER_ID=...
WHATSAPP_VERIFY_TOKEN=...         # Self-chosen token for webhook verification

# ─── ENS / Ethereum ─────────────────────────────────────────────────────────
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
DEPLOYER_PRIVATE_KEY=0x...

# ─── Backend ─────────────────────────────────────────────────────────────────
API_BASE_URL=https://api.wepay.eth.limo
PORT=3001
NODE_ENV=development

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_MOONPAY_ENV=sandbox
NEXT_PUBLIC_WEPAY_TREASURY_ADDRESS=0x...
NEXT_PUBLIC_WEPAY_REGISTRAR_ADDRESS=0x...
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=...
NEXT_PUBLIC_ALCHEMY_KEY=...
