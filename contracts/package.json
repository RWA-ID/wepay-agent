{
  "name": "@wepay/contracts",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:forge": "forge test --fork-url $ETH_RPC_URL -vvv",
    "deploy": "hardhat run scripts/deploy.ts --network mainnet",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network sepolia",
    "verify": "hardhat run scripts/verify.ts --network mainnet",
    "clean": "hardhat clean && forge clean"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.0.0",
    "hardhat": "^2.22.0",
    "typescript": "^5.5.0",
    "@types/node": "^22.0.0",
    "dotenv": "^16.0.0",
    "ts-node": "^10.9.0"
  }
}
